# ── Database ──────────────────────────────────────────────────
# Local development (relative path)
DATABASE_URL="file:./dev.db"

# Railway production (persistent volume mounted at /data)
# DATABASE_URL="file:/data/dev.db"

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── CORS ──────────────────────────────────────────────────────
# Set this to your Vercel frontend URL in Railway environment variables
# FRONTEND_URL=https://your-app.vercel.app
